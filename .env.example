# OpenRouter（AI 增强链路可选）
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Telegram Bot（必填，用于 npm run tg）
TELEGRAM_BOT_TOKEN=

# Live Monitor 告警（可选）
TELEGRAM_ALERT_CHAT_ID=
LIVE_MONITOR_PORT=3001

# 本地模型评分服务
LOCAL_MODEL_URL=http://localhost:8001/score

# ============================================
# 灰度发布配置（Live Monitor 上线前必须配置）
# ============================================

# 启用灰度限制
GRAY_RELEASE_ENABLED=false

# 灰度项目限制（只允许这个项目）
GRAY_PROJECT_ID=lanton

# 灰度入口限制（只允许这个来源）
GRAY_ENTRY_SOURCE=live-monitor-api

# 灰度测试群ID（告警先发这里，不进正式群）
GRAY_TEST_CHAT_ID=

# 灰度测试员工ID列表（逗号分隔，空表示不限制）
GRAY_TEST_EMPLOYEES=emp001,emp002

# 灰度开始/结束日期
GRAY_START_DATE=
GRAY_END_DATE=

# 每日最大评估次数（灰度期间限制）
GRAY_MAX_DAILY=1000

# ============================================
# MySQL 数据库配置（生产环境持久化）
# ============================================

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=trainer_core
