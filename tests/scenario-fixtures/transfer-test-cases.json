{
  "description": "转账未到账场景测试数据",
  "projectId": "lanton",
  "scenarioId": "lanton_transfer_success_not_received",
  "testCases": [
    {
      "name": "第一阶段完整回复",
      "conversation": [
        { "role": "customer", "content": "我转账成功了但对方没收到钱" }
      ],
      "currentReply": "您好！请您提供付款账单截图和Lanton绑定手机号，以便我们协助查询。我们会尽快为您核查处理。",
      "expectedLevel": "borderline",
      "expectedRisk": "low"
    },
    {
      "name": "缺少关键信息",
      "conversation": [
        { "role": "customer", "content": "转账没到账" }
      ],
      "currentReply": "您好，请您耐心等待",
      "expectedLevel": "fail",
      "missingKeywords": ["账单截图", "绑定手机号"]
    },
    {
      "name": "态度问题+禁忌内容",
      "conversation": [
        { "role": "customer", "content": "转账没到账怎么办？" }
      ],
      "currentReply": "这个你自己联系银行吧，我们不管这个。",
      "expectedLevel": "risk",
      "expectedRisk": "high",
      "forbiddenKeywords": ["你自己联系银行"]
    }
  ]
